# OTel Collector — Grafana Cloud credentials
# Get these from: Grafana Cloud → Connections → OpenTelemetry → Connection details
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
GRAFANA_CLOUD_OTLP_USERNAME=<instance-id>
GRAFANA_CLOUD_OTLP_PASSWORD=<grafana-cloud-token-with-metrics-traces-logs-write-scope>
