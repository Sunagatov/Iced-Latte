<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--  CONSOLE LOGGING CONFIGURATION  -->
    <appender name="ConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d [%thread] %-5level %-30logger{30} traceId=%X{traceId:--} spanId=%X{spanId:--} userId=%X{userId:--} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProperty scope="context" name="application_name" source="spring.application.name"/>

    <!--  FILE LOGGING CONFIGURATION  -->
    <appender name="FileAppender" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/iced-latte.log</file>

        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <timeZone>UTC</timeZone>
                </timestamp>
                <version/>
                <logLevel/>
                <message/>
                <loggerName/>
                <threadName/>
                <context/>
                <pattern>
                    <omitEmptyFields>true</omitEmptyFields>
                    <pattern>
                        {
                        "trace": {
                        "traceId": "%X{traceId}",
                        "spanId": "%X{spanId}",
                        "userId": "%X{userId}"
                        }
                        }
                    </pattern>
                </pattern>
                <mdc>
                    <excludeMdcKeyName>traceId</excludeMdcKeyName>
                    <excludeMdcKeyName>spanId</excludeMdcKeyName>
                    <excludeMdcKeyName>parentId</excludeMdcKeyName>
                </mdc>
                <stackTrace/>
            </providers>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/iced-latte-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>1MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10MB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <appender name="AsyncConsole" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="ConsoleAppender"/>
    </appender>

    <appender name="AsyncFile" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FileAppender"/>
    </appender>

    <!-- Suppress OTEL exporter connection errors when no collector is running locally.
         These fire every ~8 min with a 40-line stack trace and are expected in dev. -->
    <logger name="io.opentelemetry.exporter.internal.http.HttpExporter" level="OFF"/>

    <!-- Suppress Spring Data Redis bootstrap noise: 13 INFO lines per startup explaining
         that JPA repositories are not Redis repositories. Zero operational value. -->
    <logger name="org.springframework.data.repository.config.RepositoryConfigurationExtensionSupport" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="AsyncConsole"/>
        <appender-ref ref="AsyncFile"/>
    </root>

</configuration>
