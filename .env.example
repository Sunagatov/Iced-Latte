# =============================================================================
# Iced Latte — Local Development Environment
# =============================================================================
# All values here work out of the box for local development.
# Start the infrastructure first:
#   docker compose up -d postgres redis minio minio-init
# Then run the app from IntelliJ or:
#   export $(cat .env | xargs) && mvn spring-boot:run
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
APP_SERVER_PORT=8083
SPRING_PROFILES_ACTIVE=prod


# -----------------------------------------------------------------------------
# Database  (matches the 'postgres' Docker container)
# -----------------------------------------------------------------------------
DATASOURCE_HOST=localhost
DATASOURCE_PORT=5432
DATASOURCE_NAME=postgres
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=postgres


# -----------------------------------------------------------------------------
# Redis  (matches the 'redis' Docker container)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# Object Storage — MinIO  (local S3-compatible, matches the 'minio' container)
# Console UI: http://localhost:9001  login: minioadmin / minioadmin
# -----------------------------------------------------------------------------
AWS_ENABLED=true
AWS_ENDPOINT_URL=http://localhost:9000
AWS_PUBLIC_URL_BASE=http://localhost:9000/iced-latte-products
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
AWS_PRODUCT_BUCKET=iced-latte-products
AWS_USER_BUCKET=iced-latte-users
AWS_DEFAULT_PRODUCT_IMAGES_PATH=./seed/products


# -----------------------------------------------------------------------------
# JWT  (safe local secrets — do NOT reuse in production)
# -----------------------------------------------------------------------------
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
APP_JWT_REFRESH_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970


# -----------------------------------------------------------------------------
# Email  (disabled by default — set EMAIL_ENABLED=true when you need it)
# -----------------------------------------------------------------------------
EMAIL_ENABLED=false
MAIL_USERNAME=youricedlatteshop@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here


# -----------------------------------------------------------------------------
# Google OAuth  (disabled by default — set GOOGLE_ENABLED=true when you need it)
# Get credentials: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=local
GOOGLE_AUTH_CLIENT_SECRET=local
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8083/api/v1/auth/google/callback


# -----------------------------------------------------------------------------
# Stripe  (disabled by default — set STRIPE_ENABLED=true when you need it)
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder


# -----------------------------------------------------------------------------
# AI / OpenAI  (disabled by default — set AI_ENABLED=true when you need it)
# -----------------------------------------------------------------------------
AI_ENABLED=false
SPRING_AI_OPENAI_API_KEY=local-placeholder


# -----------------------------------------------------------------------------
# Frontend URL  (used for CORS and OAuth redirects)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Proxy / Rate Limiting
# -----------------------------------------------------------------------------
# Comma-separated proxy IPs allowed to set X-Forwarded-For. Leave empty for direct local access.
SECURITY_RATE_LIMIT_TRUSTED_PROXIES=


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Requests at or above this threshold are logged at WARN in the access log.
LOGGING_SLOW_REQUEST_THRESHOLD_MS=500

§
# -----------------------------------------------------------------------------
# Observability / OpenTelemetry  (disabled by default — no local collector)
# Set OTEL_EXPORTER_ENABLED=true when running with the monitoring profile.
# -----------------------------------------------------------------------------
OTEL_EXPORTER_ENABLED=false
