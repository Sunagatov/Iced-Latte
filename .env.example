# =============================================================================
# Iced Latte — Local Development Environment
# =============================================================================
# All values here work out of the box for local development.
# Stripe, Google OAuth, email, AI, and remote observability are disabled by
# default so localhost runs do not need production credentials.
# Start the infrastructure first:
#   docker compose --env-file .env.example up -d postgres redis minio minio-init
# Then run the app from IntelliJ or:
#   set -a && source .env.example && set +a && mvn spring-boot:run
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
APP_SERVER_PORT=8083
# Docker host port for the backend container. Override if 8083 is already busy.
BACKEND_HOST_PORT=8083
# Contributor default: use the full developer experience locally.
# This enables Swagger UI, DEBUG app logs, and Liquibase reseeding on restart.
SPRING_PROFILES_ACTIVE=dev
HTTP_ACCESS_LOG_LEVEL=DEBUG


# -----------------------------------------------------------------------------
# Database  (matches the 'postgres' Docker container)
# -----------------------------------------------------------------------------
DATASOURCE_HOST=localhost
DATASOURCE_PORT=5432
DATASOURCE_NAME=postgres
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=postgres
# Keep SSL off for the local Docker database.
DATASOURCE_SSL_MODE=disable


# -----------------------------------------------------------------------------
# Redis  (matches the 'redis' Docker container)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false


# -----------------------------------------------------------------------------
# Object Storage — MinIO  (local S3-compatible, matches the 'minio' container)
# Console UI: http://localhost:9001  login: minioadmin / minioadmin
# -----------------------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CONTAINER_PORT=9000
MINIO_CONSOLE_CONTAINER_PORT=9001
MINIO_HEALTH_URL=http://127.0.0.1:9000
AWS_ENABLED=true
AWS_ENDPOINT_URL=http://localhost:9000
AWS_DOCKER_ENDPOINT_URL=http://minio:9000
AWS_PUBLIC_URL_BASE=http://localhost:9000/iced-latte-products
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
AWS_PRODUCT_BUCKET=iced-latte-products
AWS_USER_BUCKET=iced-latte-users
AWS_DEFAULT_PRODUCT_IMAGES_PATH=./seed/products


# -----------------------------------------------------------------------------
# JWT  (safe local secrets — do NOT reuse in production)
# -----------------------------------------------------------------------------
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
APP_JWT_REFRESH_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970


# -----------------------------------------------------------------------------
# Email  (disabled by default — set EMAIL_ENABLED=true when you need it)
# -----------------------------------------------------------------------------
EMAIL_ENABLED=false
MAIL_USERNAME=youricedlatteshop@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here


# -----------------------------------------------------------------------------
# Google OAuth  (disabled by default — set GOOGLE_ENABLED=true when you need it)
# Get credentials: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=false
GOOGLE_AUTH_SERVER_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_AUTH_SCOPE="openid https://www.googleapis.com/auth/userinfo.profile https://www.googleapis.com/auth/userinfo.email"
GOOGLE_AUTH_CLIENT_ID=local
GOOGLE_AUTH_CLIENT_SECRET=local
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8083/api/v1/auth/google/callback


# -----------------------------------------------------------------------------
# Stripe  (TEST MODE ONLY — no real money is charged)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Use Stripe test cards: https://docs.stripe.com/testing#cards
# Example test card: 4242 4242 4242 4242, any future expiry, any CVC
# Do NOT use real card details. Do NOT use live keys (sk_live_...).
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder


# -----------------------------------------------------------------------------
# AI / OpenAI  (disabled by default — set AI_ENABLED=true when you need it)
# -----------------------------------------------------------------------------
AI_ENABLED=false
SPRING_AI_OPENAI_API_KEY=local-placeholder
AI_BASE_URL=https://models.inference.ai.azure.com
AI_MODEL_NAME=gpt-4o-mini


# -----------------------------------------------------------------------------
# Frontend URL  (used for CORS and OAuth redirects)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
# Docker host port for the frontend container. Override if 3000 is already busy.
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=3000
PROBLEM_TYPE_BASE_URL=http://localhost:8083/errors
NEXT_IMAGE_REMOTE_SOURCES=http://localhost:9000

# Frontend-in-Docker API target.
# Leave the default when both frontend and backend run in Docker.
# If frontend runs in Docker but backend runs locally, use:
#   FRONTEND_DOCKER_API_URL=http://host.docker.internal:8083/api/v1
FRONTEND_DOCKER_API_URL=http://iced-latte-backend:8083/api/v1


# -----------------------------------------------------------------------------
# Proxy / Rate Limiting
# -----------------------------------------------------------------------------
# Comma-separated proxy IPs allowed to set X-Forwarded-For. Leave empty for direct local access.
SECURITY_RATE_LIMIT_TRUSTED_PROXIES=


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Requests at or above this threshold are logged at WARN in the access log.
LOGGING_SLOW_REQUEST_THRESHOLD_MS=500

# -----------------------------------------------------------------------------
# Observability / OpenTelemetry  (disabled by default — no local collector)
# Keep local contributor runs quiet and self-contained unless you explicitly opt in.
# `DD_API_KEY` is only needed if you enable the optional `monitoring` profile.
# -----------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
LOKI_ENABLED=false
LOKI_URL=
LOGSTASH_ENABLED=false
LOGSTASH_HOST=
LOGSTASH_PORT=
DATADOG_ENABLED=false
OTEL_EXPORTER_ENABLED=false
OTEL_COLLECTOR_BASE_URL=
MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=false
MANAGEMENT_LOGGING_EXPORT_OTLP_ENABLED=false
MANAGEMENT_TRACING_ENABLED=false
MANAGEMENT_HEALTH_MAIL_ENABLED=false
PYROSCOPE_ENABLED=false
DD_API_KEY=
