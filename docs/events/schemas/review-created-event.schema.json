{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iced-latte.local/events/review-created-event.schema.json",
  "title": "ReviewCreatedEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "sourceApp",
    "occurredAt",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "enum": [
        "review.created"
      ]
    },
    "eventVersion": {
      "enum": [
        1
      ]
    },
    "sourceApp": {
      "enum": [
        "iced-latte"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": [
        "string",
        "null"
      ]
    },
    "actorId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewId",
        "productId",
        "text"
      ],
      "properties": {
        "reviewId": {
          "type": "string",
          "format": "uuid"
        },
        "productId": {
          "type": "string",
          "format": "uuid"
        },
        "text": {
          "type": "string"
        }
      }
    }
  }
}
